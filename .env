# API ENDPOINTS
BASE_CANONICAL_URL=https://ui.adsabs.harvard.edu
API_HOST_CLIENT=https://devapi.adsabs.harvard.edu/v1
API_HOST_SERVER=https://devapi.adsabs.harvard.edu/v1
NEXT_PUBLIC_API_HOST_CLIENT=https://devapi.adsabs.harvard.edu/v1

# CRAWLERS
VERIFIED_BOTS_ACCESS_TOKEN=
UNVERIFIABLE_BOTS_ACCESS_TOKEN=
MALICIOUS_BOTS_ACCESS_TOKEN=

# MISC
REACT_EDITOR=code

# APP CONFIG
NEXT_PUBLIC_SEARCH_API_TIMEOUT_MS=30000
NEXT_PUBLIC_SEARCH_SSR_API_TIMEOUT_MS=10000
PORT=8000
NEXT_PUBLIC_API_MOCKING=
# logs: debug, info, warning, error, fatal
APP_LOG_LEVEL=debug
CSRF_HEADER=X-CSRFToken

# SENTRY.IO
SENTRY_HOST=https://sentry.io
SENTRY_ORG=adsabs
SENTRY_TUNNEL=/api/monitor
SENTRY_PROJECT=nectar
# logs: debug, info, warning, error, fatal
SENTRY_LOG_LEVEL=info
SENTRY_LOAD_DOTENV=0
